# Copy to .env and edit. .env is gitignored.

# Postgres password (used by docker-compose)
NOTES_DB_PW=changeme

# Public URL the app is reachable at (used for cookie Secure flag, WebAuthn RP-ID, CalDAV URLs)
PUBLIC_URL=http://localhost:8080

# Server bind address (inside container)
BIND_ADDR=0.0.0.0:8080

# Set to "development" to relax cookie Secure flag and enable verbose logging
APP_ENV=development

# Session lifetime (e.g. "30d", "12h")
SESSION_TTL=30d
